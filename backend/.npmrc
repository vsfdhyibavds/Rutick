# NPM Configuration for Security
# This file enforces security best practices during npm operations

# Prevent audit warnings from being too verbose
audit-level=moderate

# Use exact versions, no ranges
save-exact=true

# Always install exact versions from package-lock.json
prefer-offline=true

# Don't install optional dependencies that might have vulnerabilities
no-optional=true

# Use legacy Python if needed (for some native modules)
legacy-peer-deps=false

# Maximum security for production
production=true

# Cache validation for offline mode
cache-min=9999999

# Integrity checking for all packages
strict-ssl=true
