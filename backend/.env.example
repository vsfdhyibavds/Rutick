# ========================================
# RUTick - Environment Configuration
# ========================================
# IMPORTANT: Copy this file to .env and update all values
# Never commit .env file to version control!

# ========================================
# Server Configuration
# ========================================
PORT=5000
NODE_ENV=development
# NODE_ENV options: development, production, test

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
# Local PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rutick
DB_USER=postgres
DB_PASSWORD=postgres

# For Docker PostgreSQL, use:
# DB_HOST=postgres
# DB_USER=rutick_user
# DB_PASSWORD=rutick_password_change_me

# ========================================
# JWT Authentication (CRITICAL - Change these!)
# ========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_characters_long
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=change_me_to_another_long_random_string_at_least_32_characters

# ========================================
# Email Configuration
# ========================================
# Gmail: Use app password (not account password)
# Enable 2FA and create app password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_16_characters_generated_by_google
SMTP_FROM=noreply@riarauniversity.ac.ke

# ========================================
# Frontend URLs
# ========================================
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://rutick.riarauniversity.ac.ke

# ========================================
# QR Code Settings
# ========================================
QR_CODE_SIZE=300

# ========================================
# Pagination & File Upload
# ========================================
PAGE_LIMIT=20
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ========================================
# Security Settings
# ========================================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
# Set to false to disable: SESSION_SECURE_COOKIES=true

# ========================================
# Certificate Settings
# ========================================
CERTIFICATE_FONT_PATH=./fonts/Arial.ttf

# ========================================
# Logging
# ========================================
LOG_LEVEL=debug
# Options: error, warn, info, debug
CERTIFICATE_FONT_PATH=./fonts/Arial.ttf
